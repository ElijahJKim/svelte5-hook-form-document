---
const NPM_INSTALL = "npm install svelte5-hook-form";
---

<section class="cta-section" data-cta-npm>
  <div class="cta-card">
    <div class="glow-effect"></div>

    <div class="content">
      <h2>Ready to build better forms?</h2>
      <p>
        The most lightweight, type-safe form engine ever built for Svelte 5.
        Minimal effort, maximum performance, zero overhead.
      </p>

      <div class="actions">
        <a href="/guides/introduction/" class="btn primary">
          Start Documentation
        </a>
        <button
          type="button"
          class="btn secondary"
          data-npm-copy
          data-install-cmd={NPM_INSTALL}
          aria-label={`Copy to clipboard: ${NPM_INSTALL}`}
        >
          <span class="btn-label" data-npm-label>Install via NPM</span>
        </button>
      </div>
      <p
        class="visually-hidden"
        role="status"
        aria-live="polite"
        data-npm-status
      ></p>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector("[data-cta-npm]");
  const btn = root?.querySelector("[data-npm-copy]");
  const labelEl = root?.querySelector("[data-npm-label]");
  const statusEl = root?.querySelector("[data-npm-status]");

  const defaultLabel = "Install via NPM";
  const copiedLabel = "Copied!";
  const resetMs = 2000;

  async function copyToClipboard(text) {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return true;
    }
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.setAttribute("readonly", "");
    ta.style.position = "fixed";
    ta.style.left = "-9999px";
    document.body.appendChild(ta);
    ta.select();
    const ok = document.execCommand("copy");
    document.body.removeChild(ta);
    return ok;
  }

  let resetTimer = 0;

  btn?.addEventListener("click", async () => {
    if (!labelEl || !statusEl || !btn) return;
    const cmd = btn.dataset.installCmd;
    if (!cmd) return;

    try {
      await copyToClipboard(cmd);
      labelEl.textContent = copiedLabel;
      statusEl.textContent = "Install command copied to clipboard.";
      window.clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => {
        labelEl.textContent = defaultLabel;
        statusEl.textContent = "";
      }, resetMs);
    } catch {
      statusEl.textContent =
        "Could not copy. Select the command from the quick start guide.";
    }
  });
</script>

<style>
  .cta-section {
    padding: 6rem 0;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .cta-card {
    position: relative;
    background-color: #1e1e2e; /* 코드 윈도우와 동일한 다크 배경 */
    border-radius: 2rem;
    padding: 5rem 2rem;
    text-align: center;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .glow-effect {
    position: absolute;
    inset: -5rem;

    filter: blur(80px);
    border-radius: 50%;
    z-index: 0;
  }

  .content {
    position: relative;
    z-index: 1;
    max-width: 750px;
    margin: 0 auto;
  }

  .content h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem) !important;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem !important;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .content p {
    font-size: 1.25rem;
    color: #94a3b8; /* slate-400 */
    line-height: 1.6;
    margin-bottom: 3rem;
  }

  .actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none !important;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn.primary {
    background-color: #ffffff;
    color: #111111;
  }

  .btn.primary:hover {
    background-color: #e2e8f0;
    transform: translateY(-2px);
  }

  .btn.secondary {
    min-width: 14rem;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      monospace;
  }

  .btn.secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .cta-card {
      padding: 4rem 1.5rem;
    }
    .content h2 {
      font-size: 2rem !important;
    }
    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
