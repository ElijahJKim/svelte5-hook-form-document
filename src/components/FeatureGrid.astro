--- // docs/src/components/FeatureGrid.astro --- 

const features = [
  {
    title: "Svelte 5 Native",
    description: "Built from the ground up using Runes. Experience seamless reactivity with $state and $derived without the overhead.",

  },
  {
    title: "End-to-End Type Safety",
    description: "Built with TypeScript first. Enjoy perfect schema inference and compile-time error checking for your forms.",
  },
  {
    title: "Intuitive API",
    description: "Minimal learning curve. Familiar patterns inspired by industry standards, optimized for the Svelte compiler.",
  },
  {
    title: "Flexible Validation",
    description: "From simple required fields to complex asynchronous logic, handle any validation scenario with ease.",
  },
  {
    title: "Advanced State Tracking",
    description: "Effortlessly monitor form status including isDirty, isValid, and isSubmitting in real-time.",
  },
  {
    title: "Zero Dependencies",
    description: "A lightweight powerhouse with no external bloat. Pure performance focused on your core form logic.",
  }
];
---

<section class="feature-section">
  <div class="feature-header">
    <h1>Why <span class="hightlight">Svelte5</span> Hook Form?</h1>
    <p>Reimagined to be invisible. Focus on your user experience while we handle the boilerplate and state management.</p>
  </div>

  <div class="grid">
    {features.map((feature) => (
      <div class="card">
        <h2>{feature.title}</h2>
        <p>{feature.description}</p>
        <div class="decoration"></div>
      </div>
    ))}
  </div>
</section>

<style>
  .feature-section {
    padding: 4rem 0;
    max-width: 1200px;
    margin: 0 auto;
  }

  .feature-header {
    margin-bottom: 3.5rem;
    max-width: 800px;
  }

  .header h1 {
    font-size: 3rem !important;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1.5rem !important;
    color: var(--sl-color-white);
  }

  .header p {
    font-size: 1.25rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .card {
    position: relative;
    padding: 2.5rem;
    background-color: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.25rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin:0;
  }

  .card:hover {
    border-color:  #FE3F00;

    box-shadow: 0 12px 30px -10px rgba(0, 0, 0, 0.3);
  }

  .card h2 {
    font-size: 1.5rem !important;
    font-weight: 700;
    margin-bottom: 1rem !important;
    color: var(--sl-color-white);
  }

  .card p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .decoration {
    position: absolute;
    bottom: -30px;
    right: -30px;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background-color: var(--sl-color-accent);
    opacity: 0.03;
    filter: blur(30px);
  }

  .hightlight{
    color: #FE3F00
  }

  @media (max-width: 768px) {
    .header h1 { font-size: 2.25rem !important; }
    .grid { grid-template-columns: 1fr; }
  }
</style>