---
/* docs/src/components/CustomHero.astro */
---

<div class="custom-hero-wrapper">
  <div class="hero-content">
    <h1>The New Standard for<br/><span class="highlight">Svelte5</span> Forms.</h1>
    <p>Reimagined to be invisible. Focus on your user experience while we handle the boilerplate and state management.</p>
    <div class="actions">
      <a href="/guides/introduction/" class="btn primary">Get Started &rarr;</a>
      <a href="https://github.com/ElijahJKim/svelte5-hook-form" class="btn secondary">View on GitHub ↗</a>
    </div>
  </div>

  <div class="hero-image">
    <div class="code-container">
      <div class="glow-effect"></div>
      
      <div class="code-window">
        <div class="window-header">
          <div class="mac-dots">
            <div class="dot red"></div>
            <div class="dot yellow"></div>
            <div class="dot green"></div>
          </div>
          <span class="filename">ILoveSvelte.svelte</span>
        </div>
        
        <div class="window-body">
          <pre><code><span class="dim">&lt;script&gt;</span>
  <span class="kw">import</span> &#123; createForm &#125; <span class="kw">from</span> <span class="str">'svelte5-hook-form'</span>;

  <span class="com">// Native Svelte 5 Runes support</span>
  <span class="kw">const</span> &#123; register, handleSubmit, errors &#125; = <span class="var">createForm()</span>;
<span class="dim">&lt;/script&gt;</span>

<span class="tag">&lt;form onsubmit=&#123;</span>handleSubmit<span class="tag">&#125;&gt;</span>
  <span class="tag">&lt;input ...&#123;</span>register(<span class="str">'email'</span>, &#123; required: <span class="kw">true</span> &#125;)<span class="tag">&#125; /&gt;</span>
  <span class="var">&#123;#if $errors.email&#125;</span>
    <span class="tag">&lt;span&gt;</span>Email is required<span class="tag">&lt;/span&gt;</span>
  <span class="var">&#123;/if&#125;</span>
  <span class="tag">&lt;button type="submit"&gt;</span>Submit<span class="tag">&lt;/button&gt;</span>
<span class="tag">&lt;/form&gt;</span></code></pre>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .custom-hero-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding: 4rem 0;
    max-width: 1280px;
    margin: 0 auto;

  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem) !important;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem !important;
    color: var(--sl-color-white);
    letter-spacing: -0.02em;
  }

  .hero-content p {
    font-size: 1.25rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.8rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none !important;
    transition: all 0.2s ease;
  }

  .btn.primary {
    background-color:  #FE3F00;
    color: white;
  }

  .btn.primary:hover {
    background-color:rgb(200, 59, 12);
  }

  .btn.secondary {
    background-color: transparent;
    border: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }

  .btn.secondary:hover {
    border-color: var(--sl-color-white);
  }

  .code-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .glow-effect {
    position: absolute;
    inset: -2rem;
    background-color: rgba(255, 62, 0, 0.15);
    filter: blur(60px);
    border-radius: 50%;
    z-index: 0;
  }

  .code-window {
    position: relative;
    background-color: #1e1e2e;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 1;
  }

  .window-header {
    background-color: rgba(255, 255, 255, 0.05);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mac-dots {
    display: flex;
    align-items:center;
    gap: 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin:0;
  }
  .dot.red { background-color: #ff5f56; }
  .dot.yellow { background-color: #ffbd2e; }
  .dot.green { background-color: #27c93f; }

  .filename {
    font-size: 0.75rem;
    font-weight: 500;
    color: #94a3b8;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .window-body {
    padding: 1.5rem;
    overflow-x: auto;
  }

  .window-body pre {
    margin: 0;
    font-size: 14px;
    line-height: 1.625;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: #cbd5e1;
    background: transparent !important;
    border: none !important;
  }

  .dim { color: #5eead4; }
  .kw { color: #818cf8; }
  .str { color: #fdba74; }
  .com { color: #64748b; }
  .var { color: #34d399; }
  .tag { color: #94a3b8; }

  @media (max-width: 900px) {
    .custom-hero-wrapper {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    .actions {
      justify-content: center;
    }
  }

  /* 1. Starlight 기본 제목(#_top)을 감싸고 있는 부모 패널 전체를 숨깁니다 */
  :global(.content-panel:has(#_top)) {
    display: none !important;
  }

  /* 2. (혹시 모를 대비책) 첫 번째 content-panel 강제 숨김 */
  :global(main > .content-panel:first-of-type) {
    display: none !important;
  }

  /* 3. 랜딩 페이지에 남아있는 모든 패널의 테두리(가로선)를 완벽하게 제거 */
  :global(.content-panel) {
    border: none !important;
  }

  :global(.sl-markdown-content){
   
  }

  .highlight{
    color: #FE3F00
  }

  /* 헤더 전체 배경색 및 하단 테두리 수정 */
:global(.header) {
  background-color: rgba(11, 14, 20, 0.8) !important; /* 반투명 배경 */
  backdrop-filter: blur(10px); /* 뒤가 비치는 유리 효과 */

}

/* 사이트 이름(로고 옆 텍스트) 스타일 수정 */
:global(.site-title) {
  font-weight: 800 !important;
  letter-spacing: -0.05em;
  color:  white !important; /* Svelte 오렌지색 적용 */
}

/* 검색창 디자인 수정 */
:global(.search-stats) {
  border-radius: 999px !important;
}
</style>